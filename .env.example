# Supabase - Backend (Postgres, Auth, Realtime, Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for service role operations (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox - Map display (free tier: 50k map loads/month)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Stripe - Payments
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Resend - Transactional email (booking confirmation, etc.)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Uploadthing - Station photo uploads
UPLOADTHING_SECRET=sk_live_xxx
UPLOADTHING_APP_ID=your-app-id
# For dev: use UPLOADTHING_TOKEN in dashboard
